---
/**
 * Card — the atomic unit. Name, one-line thesis, a rendered preview slot,
 * mono meta row. Surface on bg with a 1px hairline and flat radius; hover
 * changes ink (border), never elevation. Never title-only.
 */
interface Props {
  name: string;
  thesis: string;
  meta?: string[];
  href?: string;
}
const { name, thesis, meta = [], href } = Astro.props;
const Tag = href ? 'a' : 'article';
---

<Tag class="card" href={href}>
  <h3 class="card-name">{name}</h3>
  <p class="card-thesis">{thesis}</p>
  <div class="card-preview"><slot /></div>
  {meta.length > 0 && (
    <ul class="card-meta">
      {meta.map((m) => <li>{m}</li>)}
    </ul>
  )}
</Tag>

<style>
  .card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    color: inherit;
    text-decoration: none;
    transition: border-color var(--motion-duration-fast) var(--motion-easing-default);
  }
  .card:hover {
    border-color: var(--color-accent);
  }
  .card-name {
    font-family: var(--font-display);
    font-size: var(--text-md);
    color: var(--color-ink);
    margin: 0 0 var(--space-1);
  }
  .card-thesis {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-4);
  }
  .card-preview {
    background: var(--color-recessed, var(--color-bg));
    border: 1px solid var(--color-border-faint, var(--color-border));
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink);
    overflow-x: auto;
  }
  .card-meta {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
  }
  .card-meta li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-kicker, 0.09em);
    text-transform: uppercase;
    color: var(--color-ink-faint, var(--color-ink-muted));
  }
</style>
