{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-dna.dev/schema/design-dna.schema.json",
  "title": "design-dna",
  "description": "Schema for a design-dna repository: an open, portable format for a person's design taste. A repo conforms when its manifest.json validates against #/$defs/manifest and every vibe listed there has a tokens/<id>/tokens.json validating against #/$defs/tokenFile.",
  "$defs": {
    "manifest": {
      "type": "object",
      "description": "manifest.json — the repo's entry point. Lists the named vibes and where everything lives.",
      "required": ["name", "version", "vibes"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Instance identifier, kebab-case (usually the owner's handle)."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semver of this instance."
        },
        "description": { "type": "string" },
        "owner": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        },
        "vibes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/vibe" }
        },
        "patterns": {
          "type": "array",
          "description": "Stacks with pattern recipes under patterns/<stack>/.",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
        }
      }
    },
    "vibe": {
      "type": "object",
      "required": ["id", "name", "mode", "description"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Directory name under tokens/. tokens/<id>/tokens.json must exist."
        },
        "name": { "type": "string", "minLength": 1 },
        "mode": {
          "enum": ["light", "dark"],
          "description": "The canvas the vibe is designed on. One mode per vibe in v1; a dark twin is a second vibe."
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "One or two sentences a stranger could pick a vibe by."
        },
        "source": {
          "type": "string",
          "description": "Provenance — the project/identity this vibe was extracted from."
        }
      }
    },
    "tokenFile": {
      "type": "object",
      "description": "tokens/<vibe>/tokens.json — DTCG-format ($type/$value) design tokens. The required groups and names below are the minimum semantic contract every consumer may rely on; extra groups and tokens are allowed.",
      "required": ["color", "font", "text", "space", "radius", "motion"],
      "additionalProperties": { "$ref": "#/$defs/group" },
      "properties": {
        "color": {
          "type": "object",
          "required": ["bg", "surface", "ink", "ink-muted", "border", "accent", "accent-ink"],
          "additionalProperties": { "$ref": "#/$defs/colorToken" },
          "properties": {
            "bg": { "$ref": "#/$defs/colorToken" },
            "surface": { "$ref": "#/$defs/colorToken" },
            "ink": { "$ref": "#/$defs/colorToken" },
            "ink-muted": { "$ref": "#/$defs/colorToken" },
            "border": { "$ref": "#/$defs/colorToken" },
            "accent": { "$ref": "#/$defs/colorToken" },
            "accent-ink": { "$ref": "#/$defs/colorToken" }
          }
        },
        "font": {
          "type": "object",
          "required": ["display", "body", "mono"],
          "additionalProperties": { "$ref": "#/$defs/fontFamilyToken" },
          "properties": {
            "display": { "$ref": "#/$defs/fontFamilyToken" },
            "body": { "$ref": "#/$defs/fontFamilyToken" },
            "mono": { "$ref": "#/$defs/fontFamilyToken" }
          }
        },
        "text": {
          "type": "object",
          "required": ["xs", "sm", "base", "md", "lg", "xl", "2xl"],
          "additionalProperties": { "$ref": "#/$defs/dimensionToken" },
          "properties": {
            "xs": { "$ref": "#/$defs/dimensionToken" },
            "sm": { "$ref": "#/$defs/dimensionToken" },
            "base": { "$ref": "#/$defs/dimensionToken" },
            "md": { "$ref": "#/$defs/dimensionToken" },
            "lg": { "$ref": "#/$defs/dimensionToken" },
            "xl": { "$ref": "#/$defs/dimensionToken" },
            "2xl": { "$ref": "#/$defs/dimensionToken" }
          }
        },
        "space": {
          "type": "object",
          "required": ["1", "2", "3", "4", "5", "6", "7", "8"],
          "additionalProperties": { "$ref": "#/$defs/dimensionToken" }
        },
        "radius": {
          "type": "object",
          "required": ["sm", "md", "lg"],
          "additionalProperties": { "$ref": "#/$defs/dimensionToken" },
          "properties": {
            "sm": { "$ref": "#/$defs/dimensionToken" },
            "md": { "$ref": "#/$defs/dimensionToken" },
            "lg": { "$ref": "#/$defs/dimensionToken" }
          }
        },
        "motion": {
          "type": "object",
          "required": ["duration", "easing"],
          "additionalProperties": { "$ref": "#/$defs/group" },
          "properties": {
            "duration": {
              "type": "object",
              "required": ["fast", "normal", "slow"],
              "additionalProperties": { "$ref": "#/$defs/durationToken" }
            },
            "easing": {
              "type": "object",
              "required": ["default"],
              "additionalProperties": { "$ref": "#/$defs/cubicBezierToken" }
            }
          }
        },
        "shadow": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/shadowToken" }
        },
        "tracking": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/dimensionToken" }
        },
        "leading": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/numberToken" }
        },
        "measure": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/dimensionToken" }
        }
      }
    },
    "group": {
      "type": "object",
      "description": "A DTCG group: nested groups and tokens.",
      "patternProperties": {
        "^\\$": {},
        "^[^$]": {
          "anyOf": [{ "$ref": "#/$defs/token" }, { "$ref": "#/$defs/group" }]
        }
      }
    },
    "token": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": {
          "enum": ["color", "dimension", "fontFamily", "fontWeight", "duration", "cubicBezier", "number", "shadow"]
        },
        "$value": {},
        "$description": { "type": "string" }
      }
    },
    "colorToken": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": { "const": "color" },
        "$value": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$",
          "description": "Hex, #RRGGBB or #RRGGBBAA. No rgb()/hsl() strings — encode alpha in the hex."
        },
        "$description": { "type": "string" }
      }
    },
    "dimensionToken": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": { "const": "dimension" },
        "$value": {
          "type": "string",
          "pattern": "^-?\\d*\\.?\\d+(px|rem|em|ch|%)$|^0$",
          "description": "A single CSS length with unit (px/rem/em/ch/%), or the literal 0."
        },
        "$description": { "type": "string" }
      }
    },
    "fontFamilyToken": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": { "const": "fontFamily" },
        "$value": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Ordered family stack, first entry is the intended face."
        },
        "$description": { "type": "string" }
      }
    },
    "durationToken": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": { "const": "duration" },
        "$value": {
          "type": "string",
          "pattern": "^\\d*\\.?\\d+(ms|s)$"
        },
        "$description": { "type": "string" }
      }
    },
    "cubicBezierToken": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": { "const": "cubicBezier" },
        "$value": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "number" }
        },
        "$description": { "type": "string" }
      }
    },
    "numberToken": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": { "const": "number" },
        "$value": { "type": "number" },
        "$description": { "type": "string" }
      }
    },
    "shadowLayer": {
      "type": "object",
      "required": ["color", "offsetX", "offsetY", "blur"],
      "properties": {
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "offsetX": { "type": "string" },
        "offsetY": { "type": "string" },
        "blur": { "type": "string" },
        "spread": { "type": "string" }
      }
    },
    "shadowToken": {
      "type": "object",
      "required": ["$type", "$value"],
      "properties": {
        "$type": { "const": "shadow" },
        "$value": {
          "anyOf": [
            { "$ref": "#/$defs/shadowLayer" },
            { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/shadowLayer" } }
          ]
        },
        "$description": { "type": "string" }
      }
    }
  }
}
