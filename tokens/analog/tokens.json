{
  "color": {
    "bg": { "$type": "color", "$value": "#F4EFE6", "$description": "Canvas — chalky warm off-white. Pure #FFFFFF is banned." },
    "surface": { "$type": "color", "$value": "#FBF9F3", "$description": "Default block / card surface." },
    "surface-raised": { "$type": "color", "$value": "#FFFDF8", "$description": "Raised: popover, dialog." },
    "recessed": { "$type": "color", "$value": "#ECE7DB", "$description": "Wells / inputs." },
    "ink": { "$type": "color", "$value": "#1C1A17", "$description": "Primary text — warm near-black. Pure #000000 is banned." },
    "ink-muted": { "$type": "color", "$value": "#5C5349", "$description": "Secondary / meta." },
    "ink-faint": { "$type": "color", "$value": "#8C8578", "$description": "Captions / placeholder." },
    "border": { "$type": "color", "$value": "#1C1A171F", "$description": "Hairlines, not borders — ink at 12%." },
    "border-faint": { "$type": "color", "$value": "#1C1A1712", "$description": "Ink at 7%." },
    "accent": { "$type": "color", "$value": "#2B4C7E", "$description": "Left-bank blue — the brand carrier, byte-identical across analog and fluent." },
    "accent-hover": { "$type": "color", "$value": "#24406C" },
    "accent-pressed": { "$type": "color", "$value": "#1D3355" },
    "accent-ink": { "$type": "color", "$value": "#F4EFE6", "$description": "Text on accent." },
    "accent-2": { "$type": "color", "$value": "#D4472B", "$description": "Vermilion — riso misregistration + rare emphasis, ~10% coverage max." },
    "accent-3": { "$type": "color", "$value": "#B7B043", "$description": "Dirty chartreuse — the un-corporate register. Use sparingly." }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": ["Fraunces Variable", "Fraunces", "Georgia", "serif"], "$description": "Optical serif; lowercase headings. Wordmark sets opsz 144, SOFT 30, WONK 1." },
    "body": { "$type": "fontFamily", "$value": ["Source Serif 4 Variable", "Source Serif 4", "Georgia", "serif"], "$description": "Reading serif; oldstyle figures on." },
    "ui": { "$type": "fontFamily", "$value": ["Hanken Grotesk", "system-ui", "sans-serif"], "$description": "Controls and small UI." },
    "mono": { "$type": "fontFamily", "$value": ["Commit Mono", "JetBrains Mono", "ui-monospace", "monospace"], "$description": "Machine voice — kickers, metadata, counts, code." }
  },
  "text": {
    "xs": { "$type": "dimension", "$value": "0.8rem", "$description": "12.8px — kicker labels, meta." },
    "sm": { "$type": "dimension", "$value": "0.875rem", "$description": "14px — dense UI body." },
    "base": { "$type": "dimension", "$value": "1rem", "$description": "16px — body." },
    "md": { "$type": "dimension", "$value": "1.25rem", "$description": "20px — lede / subtitle." },
    "lg": { "$type": "dimension", "$value": "1.5625rem", "$description": "25px — H3. Major-third (1.25) scale." },
    "xl": { "$type": "dimension", "$value": "1.9531rem", "$description": "31.25px — H2." },
    "2xl": { "$type": "dimension", "$value": "2.4414rem", "$description": "39px — H1." },
    "3xl": { "$type": "dimension", "$value": "3.0518rem", "$description": "48.8px — page title." },
    "4xl": { "$type": "dimension", "$value": "3.8147rem", "$description": "61px — large title." }
  },
  "leading": {
    "tight": { "$type": "number", "$value": 1.1 },
    "snug": { "$type": "number", "$value": 1.3 },
    "normal": { "$type": "number", "$value": 1.55 }
  },
  "tracking": {
    "kicker": { "$type": "dimension", "$value": "0.09em", "$description": "Uppercase mono kickers, 11–13px." }
  },
  "measure": {
    "default": { "$type": "dimension", "$value": "66ch", "$description": "Reading column — long-form text never exceeds this." }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px", "$description": "Baseline grid unit — vertical rhythm is multiples of this." },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" },
    "9": { "$type": "dimension", "$value": "96px" },
    "10": { "$type": "dimension", "$value": "128px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "0", "$description": "Flat / print-like. No pills, no rounded cards." },
    "md": { "$type": "dimension", "$value": "2px" },
    "lg": { "$type": "dimension", "$value": "4px" }
  },
  "motion": {
    "duration": {
      "ultrafast": { "$type": "duration", "$value": "50ms" },
      "fast": { "$type": "duration", "$value": "150ms" },
      "normal": { "$type": "duration", "$value": "200ms" },
      "slow": { "$type": "duration", "$value": "300ms" }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1], "$description": "Ink easing. Motion is punctuation: opacity/position only, never scale-pop or bounce." }
    }
  },
  "shadow": {
    "1": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "0px", "spread": "0px", "color": "#1C1A171A" }, "$description": "Deboss hairline." },
    "2": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "#2823190F" }, "$description": "Faint lift." },
    "lg": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px", "color": "#2823191A" }, "$description": "Modals only. No colored glow, ever." }
  }
}
