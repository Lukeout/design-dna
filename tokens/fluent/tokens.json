{
  "color": {
    "bg": { "$type": "color", "$value": "#F3F1EC", "$description": "~Fluent neutralBackground3, warmed toward paper. Pure #FFFFFF banned even here." },
    "surface": { "$type": "color", "$value": "#FBFAF7", "$description": "~neutralBackground1, warmed." },
    "surface-raised": { "$type": "color", "$value": "#FEFDFB", "$description": "Raised: card / dialog." },
    "recessed": { "$type": "color", "$value": "#ECEAE4", "$description": "~neutralBackground4, warmed." },
    "ink": { "$type": "color", "$value": "#262420", "$description": "~neutralForeground1, warmed." },
    "ink-muted": { "$type": "color", "$value": "#4A4740", "$description": "~neutralForeground2." },
    "ink-faint": { "$type": "color", "$value": "#706C63", "$description": "~neutralForeground3/4." },
    "border": { "$type": "color", "$value": "#D3D1CD", "$description": "~neutralStroke1, warmed — visible hairlines, Fluent style." },
    "border-faint": { "$type": "color", "$value": "#E4E1DB", "$description": "~neutralStroke2, warmed." },
    "accent": { "$type": "color", "$value": "#2B4C7E", "$description": "Same left-bank blue carrier as analog — coherence law." },
    "accent-hover": { "$type": "color", "$value": "#243F68" },
    "accent-pressed": { "$type": "color", "$value": "#1B2F4E" },
    "accent-ink": { "$type": "color", "$value": "#FBFAF7" },
    "accent-2": { "$type": "color", "$value": "#BF4A32", "$description": "Vermilion desaturated ~10% for screen luminance." }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": ["Inter Variable", "Inter", "Segoe UI", "system-ui", "sans-serif"], "$description": "Segoe substitute. Inter is the app voice here — and ONLY here (never a display face in analog)." },
    "body": { "$type": "fontFamily", "$value": ["Inter Variable", "Inter", "Segoe UI", "system-ui", "sans-serif"] },
    "ui": { "$type": "fontFamily", "$value": ["Inter Variable", "Inter", "Segoe UI", "system-ui", "sans-serif"] },
    "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono Variable", "JetBrains Mono", "ui-monospace", "monospace"] },
    "wordmark": { "$type": "fontFamily", "$value": ["Fraunces Variable", "Fraunces", "Georgia", "serif"], "$description": "Byte-identical Fraunces lockup across themes (opsz 144, SOFT 30, WONK 1)." }
  },
  "text": {
    "xs": { "$type": "dimension", "$value": "0.8rem" },
    "sm": { "$type": "dimension", "$value": "0.875rem", "$description": "14px — Fluent's dense UI body size." },
    "base": { "$type": "dimension", "$value": "1rem" },
    "md": { "$type": "dimension", "$value": "1.25rem" },
    "lg": { "$type": "dimension", "$value": "1.5625rem" },
    "xl": { "$type": "dimension", "$value": "1.9531rem" },
    "2xl": { "$type": "dimension", "$value": "2.4414rem" },
    "3xl": { "$type": "dimension", "$value": "3.0518rem" },
    "4xl": { "$type": "dimension", "$value": "3.8147rem" }
  },
  "leading": {
    "tight": { "$type": "number", "$value": 1.1 },
    "snug": { "$type": "number", "$value": 1.3 },
    "normal": { "$type": "number", "$value": 1.55 }
  },
  "measure": {
    "default": { "$type": "dimension", "$value": "72ch" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" },
    "9": { "$type": "dimension", "$value": "96px" },
    "10": { "$type": "dimension", "$value": "128px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px", "$description": "Controls." },
    "md": { "$type": "dimension", "$value": "8px", "$description": "Surfaces." },
    "lg": { "$type": "dimension", "$value": "12px", "$description": "Hero surfaces. Never 16–24px over-rounding." }
  },
  "motion": {
    "duration": {
      "ultrafast": { "$type": "duration", "$value": "50ms" },
      "fast": { "$type": "duration", "$value": "150ms" },
      "normal": { "$type": "duration", "$value": "200ms" },
      "slow": { "$type": "duration", "$value": "300ms" }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0, 0, 0, 1], "$description": "Fluent decelerate — the enter curve doubles as default." },
      "enter": { "$type": "cubicBezier", "$value": [0, 0, 0, 1] },
      "exit": { "$type": "cubicBezier", "$value": [1, 0, 1, 1], "$description": "Fluent accelerate." }
    }
  },
  "shadow": {
    "1": { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "#1C1A1724" },
      { "offsetX": "0px", "offsetY": "0px", "blur": "2px", "spread": "0px", "color": "#1C1A171F" }
    ], "$description": "Fluent shadow2 — always paired key + ambient; a single flat drop-shadow is a Tailwind tell." },
    "2": { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "4px", "blur": "8px", "spread": "0px", "color": "#1C1A1724" },
      { "offsetX": "0px", "offsetY": "0px", "blur": "2px", "spread": "0px", "color": "#1C1A171F" }
    ], "$description": "Fluent shadow8." },
    "lg": { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "14px", "blur": "28px", "spread": "0px", "color": "#1C1A1733" },
      { "offsetX": "0px", "offsetY": "0px", "blur": "8px", "spread": "0px", "color": "#1C1A171F" }
    ], "$description": "Fluent shadow28 — warm-ink-tinted, never pure black." }
  }
}
