{
  "color": {
    "bg": { "$type": "color", "$value": "#08080C", "$description": "Near-black with a blue undertone — instrument-panel dark, not #000." },
    "surface": { "$type": "color", "$value": "#0E0E14" },
    "surface-raised": { "$type": "color", "$value": "#141420" },
    "ink": { "$type": "color", "$value": "#E8E6E3", "$description": "Warm off-white text on dark." },
    "ink-muted": { "$type": "color", "$value": "#7A7880" },
    "ink-faint": { "$type": "color", "$value": "#4A4852" },
    "border": { "$type": "color", "$value": "#FFFFFF0F", "$description": "White at 6% — hairline panel seams." },
    "border-accent": { "$type": "color", "$value": "#E8913A26", "$description": "Amber at 15% — highlighted panel edges." },
    "accent": { "$type": "color", "$value": "#E8913A", "$description": "GEX-RAY amber. The one color used with conviction." },
    "accent-hover": { "$type": "color", "$value": "#F0A050" },
    "accent-pressed": { "$type": "color", "$value": "#C4692A" },
    "accent-ink": { "$type": "color", "$value": "#050507", "$description": "Near-black text on amber." },
    "accent-glow": { "$type": "color", "$value": "#E8913A1F", "$description": "Amber at 12% — glow shadows and badge fills." },
    "accent-2": { "$type": "color", "$value": "#C4451A", "$description": "Copper — the deep end of the amber gradient ramp." },
    "teal": { "$type": "color", "$value": "#3AE8C7", "$description": "Instrument teal — data/positive-signal accents only." },
    "positive": { "$type": "color", "$value": "#3AE87A" },
    "negative": { "$type": "color", "$value": "#E84A3A" }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": ["Syne", "sans-serif"], "$description": "Geometric display — wide, 700–800 weight, tight tracking." },
    "body": { "$type": "fontFamily", "$value": ["DM Sans", "sans-serif"] },
    "ui": { "$type": "fontFamily", "$value": ["DM Sans", "sans-serif"] },
    "mono": { "$type": "fontFamily", "$value": ["IBM Plex Mono", "monospace"], "$description": "The instrument voice — nav links, labels, buttons are uppercase mono." }
  },
  "text": {
    "xs": { "$type": "dimension", "$value": "0.6875rem", "$description": "11px — uppercase mono kickers and section labels." },
    "sm": { "$type": "dimension", "$value": "0.75rem", "$description": "12px — nav links, chips." },
    "base": { "$type": "dimension", "$value": "1rem" },
    "md": { "$type": "dimension", "$value": "1.125rem", "$description": "18px — card titles, logo text." },
    "lg": { "$type": "dimension", "$value": "1.75rem", "$description": "28px — feature numerals." },
    "xl": { "$type": "dimension", "$value": "2rem", "$description": "32px — stat figures." },
    "2xl": { "$type": "dimension", "$value": "3.25rem", "$description": "52px — section headlines (fluid up to 4vw)." },
    "3xl": { "$type": "dimension", "$value": "4rem", "$description": "64px — CTA headline ceiling." },
    "4xl": { "$type": "dimension", "$value": "7.5rem", "$description": "120px — hero title ceiling (fluid 8vw, floor 56px)." }
  },
  "leading": {
    "tight": { "$type": "number", "$value": 0.95, "$description": "Hero display leading." },
    "snug": { "$type": "number", "$value": 1.2 },
    "normal": { "$type": "number", "$value": 1.6 }
  },
  "tracking": {
    "tight": { "$type": "dimension", "$value": "-0.03em", "$description": "Display headlines." },
    "wide": { "$type": "dimension", "$value": "0.1em", "$description": "Uppercase mono nav/labels." },
    "kicker": { "$type": "dimension", "$value": "0.2em", "$description": "Section labels with the 24px amber rule prefix." }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "36px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" },
    "9": { "$type": "dimension", "$value": "96px" },
    "10": { "$type": "dimension", "$value": "140px", "$description": "Section padding — sections breathe." }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "0", "$description": "Square. Geometric means geometric — buttons and panels have hard corners." },
    "md": { "$type": "dimension", "$value": "0" },
    "lg": { "$type": "dimension", "$value": "3px", "$description": "The one concession — tiny chips and kbd caps only." }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "300ms", "$description": "Hover color/border shifts — deliberate, not snappy." },
      "normal": { "$type": "duration", "$value": "400ms" },
      "slow": { "$type": "duration", "$value": "700ms", "$description": "Scroll-reveal rise." }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.25, 0.1, 0.25, 1], "$description": "CSS `ease` — transitions are unshowy fades and 20px rises." }
    }
  },
  "shadow": {
    "glow": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "30px", "spread": "0px", "color": "#E8913A1F" }, "$description": "Amber CTA glow on hover — the one permitted glow." },
    "glow-lg": { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "0px", "blur": "40px", "spread": "0px", "color": "#E8913A1F" },
      { "offsetX": "0px", "offsetY": "0px", "blur": "80px", "spread": "0px", "color": "#E8913A0F" }
    ] }
  }
}
