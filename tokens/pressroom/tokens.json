{
  "color": {
    "bg": { "$type": "color", "$value": "#F6F1E7", "$description": "Paper — warm newsprint cream." },
    "surface": { "$type": "color", "$value": "#FBF7EF", "$description": "Raised paper — kbd caps, plates." },
    "ink": { "$type": "color", "$value": "#211B14", "$description": "Real ink — warm near-black, never #000." },
    "ink-muted": { "$type": "color", "$value": "#5C5245", "$description": "Soft ink — field labels, secondary copy (often italic)." },
    "ink-faint": { "$type": "color", "$value": "#93887A", "$description": "Faint ink — section labels, hints." },
    "border": { "$type": "color", "$value": "#211B1429", "$description": "Light rule — ink at 16%." },
    "border-strong": { "$type": "color", "$value": "#211B14BF", "$description": "Press rule — ink at 75%. Double rules under the masthead." },
    "accent": { "$type": "color", "$value": "#C2401C", "$description": "Vermilion — the one accent: masthead mark, fleuron, hover ink, the press-button offset plate." },
    "accent-hover": { "$type": "color", "$value": "#9E3315", "$description": "Deep vermilion." },
    "accent-pressed": { "$type": "color", "$value": "#9E3315" },
    "accent-ink": { "$type": "color", "$value": "#F6F1E7", "$description": "Paper on vermilion." },
    "accent-2": { "$type": "color", "$value": "#4A6741", "$description": "Moss — the OK/success state. Editorial green, not traffic-light green." }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": ["Iowan Old Style", "Palatino Linotype", "Palatino", "Book Antiqua", "Georgia", "serif"], "$description": "Local editorial serif stack — no webfont, no network." },
    "body": { "$type": "fontFamily", "$value": ["Iowan Old Style", "Palatino Linotype", "Palatino", "Book Antiqua", "Georgia", "serif"], "$description": "Serif throughout; italics carry the secondary voice." },
    "ui": { "$type": "fontFamily", "$value": ["Avenir Next", "Avenir", "Segoe UI", "Helvetica Neue", "Helvetica", "Arial", "sans-serif"], "$description": "Compositor's sans — uppercase micro-labels, badges, buttons." },
    "mono": { "$type": "fontFamily", "$value": ["SF Mono", "Cascadia Code", "Consolas", "Menlo", "monospace"], "$description": "Tabular values, kbd hints." }
  },
  "text": {
    "xs": { "$type": "dimension", "$value": "0.625rem", "$description": "10px — uppercase sans micro-labels (badges, colophon)." },
    "sm": { "$type": "dimension", "$value": "0.75rem", "$description": "12px — hints, buttons." },
    "base": { "$type": "dimension", "$value": "0.875rem", "$description": "14px — compact editorial body; the source surface is print-dense." },
    "md": { "$type": "dimension", "$value": "1.1875rem", "$description": "19px — proof titles / front-page heads." },
    "lg": { "$type": "dimension", "$value": "1.5rem", "$description": "24px — extrapolated up the ramp for larger surfaces." },
    "xl": { "$type": "dimension", "$value": "2rem", "$description": "32px — extrapolated." },
    "2xl": { "$type": "dimension", "$value": "2.75rem", "$description": "44px — extrapolated masthead scale." }
  },
  "leading": {
    "tight": { "$type": "number", "$value": 1.22, "$description": "Proof titles." },
    "normal": { "$type": "number", "$value": 1.45 }
  },
  "tracking": {
    "kicker": { "$type": "dimension", "$value": "0.14em", "$description": "Uppercase sans labels (publication line, badges)." },
    "label": { "$type": "dimension", "$value": "0.18em", "$description": "Section labels between flanking rules." },
    "wide": { "$type": "dimension", "$value": "0.2em", "$description": "The press button." }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "2px", "$description": "Check boxes, range thumbs — set squarish, like lead type." },
    "md": { "$type": "dimension", "$value": "3px", "$description": "Segmented controls, buttons, kbd caps." },
    "lg": { "$type": "dimension", "$value": "3px", "$description": "Nothing gets rounder than 3px except the status dot (a circle)." }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "140ms", "$description": "Ink transitions — hover color, segmented toggle." },
      "normal": { "$type": "duration", "$value": "160ms", "$description": "Check-stamp scale-in." },
      "slow": { "$type": "duration", "$value": "380ms", "$description": "Staggered rise on open (55ms per item)." }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1], "$description": "Settling-paper decelerate." },
      "stamp": { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1], "$description": "The one overshoot — the checkmark stamps in." }
    }
  },
  "shadow": {
    "press": { "$type": "shadow", "$value": { "offsetX": "3px", "offsetY": "3px", "blur": "0px", "spread": "0px", "color": "#C2401C" }, "$description": "Offset-plate shadow on the primary button; :active translates into it (the press)." }
  }
}
